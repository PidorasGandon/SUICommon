                status.TextColor3 = Color3.fromRGB(100, 255, 100)
                button.BackgroundColor3 = Color3.fromRGB(80, 200, 80)
                button.Text = "✓ OK"
                progressFill.BackgroundColor3 = Color3.fromRGB(100, 255, 100)
            elseif result == false then
                status.Text = "❌ " .. (message or "Ошибка")
                status.TextColor3 = Color3.fromRGB(255, 100, 100)
                button.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
                button.Text = "✗ FAIL"
                progressFill.BackgroundColor3 = Color3.fromRGB(255, 100, 100)
            else
                status.Text = "⚠️ " .. (message or "Недоступно")
                status.TextColor3 = Color3.fromRGB(255, 200, 100)
                button.BackgroundColor3 = Color3.fromRGB(255, 180, 80)
                button.Text = "⚠ N/A"
                progressFill.BackgroundColor3 = Color3.fromRGB(255, 200, 100)
            end
        else
            status.Text = "❌ Ошибка выполнения"
            status.TextColor3 = Color3.fromRGB(255, 100, 100)
            button.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
            button.Text = "✗ ERROR"
            progressFill.BackgroundColor3 = Color3.fromRGB(255, 100, 100)
        end
        
        task.wait(2)
        progressBar.Visible = false
        progressFill.Size = UDim2.new(0, 0, 1, 0)
        progressFill.BackgroundColor3 = Color3.fromRGB(60, 120, 255)
    end)
    
    table.insert(CheckItems, {
        button = button, 
        status = status, 
        check = checkData.check,
        item = item,
        data = checkData
    })
end

