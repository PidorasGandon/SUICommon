function Library:CreateTab(name, category)
    local TabButton = Instance.new("TextButton")
    local TabCorner = Instance.new("UICorner")
    local TabIndicator = Instance.new("Frame")
    local IndicatorCorner = Instance.new("UICorner")
    
    TabButton.Name = name
    TabButton.Parent = TabsFrame
    TabButton.BackgroundColor3 = Color3.fromRGB(30, 30, 38)
    TabButton.BorderSizePixel = 0
    TabButton.Position = UDim2.new(0, 10, 0, 10 + (#TabButtons * 45))
    TabButton.Size = UDim2.new(1, -20, 0, 38)
    TabButton.Font = Enum.Font.GothamBold
    TabButton.Text = "  " .. name
    TabButton.TextColor3 = Color3.fromRGB(200, 200, 210)
    TabButton.TextSize = 12
    TabButton.TextXAlignment = Enum.TextXAlignment.Left
    
    TabCorner.CornerRadius = UDim.new(0, 8)
    TabCorner.Parent = TabButton
    
    TabIndicator.Name = "Indicator"
    TabIndicator.Parent = TabButton
    TabIndicator.BackgroundColor3 = Color3.fromRGB(60, 120, 255)
    TabIndicator.BorderSizePixel = 0
    TabIndicator.Position = UDim2.new(0, 0, 0, 0)
    TabIndicator.Size = UDim2.new(0, 0, 1, 0)
    TabIndicator.Visible = false
    
    IndicatorCorner.CornerRadius = UDim.new(0, 8)
    IndicatorCorner.Parent = TabIndicator
    
    table.insert(TabButtons, {button = TabButton, category = category, indicator = TabIndicator})
    
    TabButton.MouseButton1Click:Connect(function()
        Library:SwitchCategory(category)
    end)
    
    return TabButton
end

function Library:SwitchCategory(category)
    CurrentCategory = category
    
    -- Обновление вкладок
    for _, tab in pairs(TabButtons) do
        if tab.category == category then
            tab.button.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
            tab.button.TextColor3 = Color3.fromRGB(255, 255, 255)
            tab.indicator.Visible = true
            game:GetService("TweenService"):Create(tab.indicator, TweenInfo.new(0.3), {
                Size = UDim2.new(0, 4, 1, 0)
            }):Play()
        else
            tab.button.BackgroundColor3 = Color3.fromRGB(30, 30, 38)
            tab.button.TextColor3 = Color3.fromRGB(200, 200, 210)
            game:GetService("TweenService"):Create(tab.indicator, TweenInfo.new(0.3), {
                Size = UDim2.new(0, 0, 1, 0)
            }):Play()
            task.wait(0.3)
            tab.indicator.Visible = false
        end
    end
    
    -- Фильтрация элементов
    for _, item in pairs(ScrollingFrame:GetChildren()) do
        if item:IsA("Frame") and item.Name ~= "UIListLayout" then
            if category == "All" then
                item.Visible = true
            else
                local itemData = nil
                for _, data in pairs(CheckFunctions) do
                    if data.name == item.Name then
                        itemData = data
                        break
                    end
                end
                
                if itemData then
                    item.Visible = itemData.category == category
                end
            end
        end
    end
end

