local function CreatePlayerSelector()
    PlayerListFrame.Name = "PlayerListFrame"
    PlayerListFrame.Parent = ScreenGui
    PlayerListFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 35)
    PlayerListFrame.BorderSizePixel = 0
    PlayerListFrame.Position = UDim2.new(0.7, 0, 0.2, 0)
    PlayerListFrame.Size = UDim2.new(0, 250, 0, 400)
    PlayerListFrame.Visible = false
    
    local PLCorner = Instance.new("UICorner")
    PLCorner.CornerRadius = UDim.new(0, 12)
    PLCorner.Parent = PlayerListFrame
    
    local PLTitle = Instance.new("TextLabel")
    PLTitle.Parent = PlayerListFrame
    PLTitle.BackgroundColor3 = Color3.fromRGB(40, 120, 255)
    PLTitle.Size = UDim2.new(1, 0, 0, 35)
    PLTitle.Font = Enum.Font.GothamBold
    PLTitle.Text = "👥 Select Player"
    PLTitle.TextColor3 = Color3.fromRGB(255, 255, 255)
    PLTitle.TextSize = 16
    
    local PLTCorner = Instance.new("UICorner")
    PLTCorner.CornerRadius = UDim.new(0, 12)
    PLTCorner.Parent = PLTitle
    
    PlayerScrollFrame.Parent = PlayerListFrame
    PlayerScrollFrame.BackgroundTransparency = 1
    PlayerScrollFrame.Position = UDim2.new(0, 5, 0, 40)
    PlayerScrollFrame.Size = UDim2.new(1, -10, 1, -45)
    PlayerScrollFrame.ScrollBarThickness = 4
    
    local PLListLayout = Instance.new("UIListLayout")
    PLListLayout.Parent = PlayerScrollFrame
    PLListLayout.Padding = UDim.new(0, 5)
    
    local function UpdatePlayerList()
        for _, child in pairs(PlayerScrollFrame:GetChildren()) do
            if child:IsA("TextButton") then
                child:Destroy()
            end
        end
        
        for _, player in pairs(game.Players:GetPlayers()) do
            if player ~= Player then
                local PlayerBtn = Instance.new("TextButton")
                PlayerBtn.Parent = PlayerScrollFrame
                PlayerBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 50)
                PlayerBtn.Size = UDim2.new(1, 0, 0, 30)
                PlayerBtn.Font = Enum.Font.Gotham
                PlayerBtn.Text = player.Name
                PlayerBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
                PlayerBtn.TextSize = 12
                
                local PBCorner = Instance.new("UICorner")
                PBCorner.CornerRadius = UDim.new(0, 6)
                PBCorner.Parent = PlayerBtn
                
                PlayerBtn.MouseButton1Click:Connect(function()
                    selectedPlayer = player
                    PLTitle.Text = "👥 Selected: " .. player.Name
                    PlayerBtn.BackgroundColor3 = Color3.fromRGB(40, 120, 255)
                    
                    for _, btn in pairs(PlayerScrollFrame:GetChildren()) do
                        if btn:IsA("TextButton") and btn ~= PlayerBtn then
                            btn.BackgroundColor3 = Color3.fromRGB(30, 30, 50)
                        end
                    end
                end)
            end
        end
        
        PlayerScrollFrame.CanvasSize = UDim2.new(0, 0, 0, PLListLayout.AbsoluteContentSize.Y)
    end
    
    UpdatePlayerList()
    
    game.Players.PlayerAdded:Connect(UpdatePlayerList)
    game.Players.PlayerRemoving:Connect(UpdatePlayerList)
end

