        marble.Anchored = true
        marble.CanCollide = false
        marble.Position = HumanoidRootPart.Position
        marble.Parent = workspace
        
        -- Изменение неба
        game.Lighting.TimeOfDay = "00:00:00"
        game.Lighting.Ambient = Color3.fromRGB(138, 43, 226)
        
        -- Звездное небо внутри
        for i = 1, 100 do
            local star = Instance.new("Part")
            star.Shape = Enum.PartType.Ball
            star.Size = Vector3.new(1, 1, 1)
            star.Material = Enum.Material.Neon
            star.Color = Color3.fromRGB(255, 255, 255)
            star.Anchored = true
            star.CanCollide = false
            
            local angle1 = math.random() * math.pi * 2
            local angle2 = math.random() * math.pi * 2
            local radius = 45
            
            star.Position = marble.Position + Vector3.new(
                math.cos(angle1) * math.cos(angle2) * radius,
                math.sin(angle2) * radius,
                math.sin(angle1) * math.cos(angle2) * radius
            )
            star.Parent = marble
            
            spawn(function()
                while star.Parent do
                    star.Size = Vector3.new(
                        math.random(1, 3),
                        math.random(1, 3),
                        math.random(1, 3)
                    )
                    wait(math.random(1, 3) / 10)
                end
            end)
        end
        
