local function CreateParticle(parent, config)
    local particle = Instance.new("ParticleEmitter")
    particle.Parent = parent
    
    particle.Texture = config.Texture or "rbxasset://textures/particles/sparkles_main.dds"
    particle.Color = config.Color or ColorSequence.new(Color3.fromRGB(255, 255, 255))
    particle.Rate = config.Rate or 50
    particle.Lifetime = config.Lifetime or NumberRange.new(1)
    particle.Speed = config.Speed or NumberRange.new(5)
    particle.Size = config.Size or NumberSequence.new(1)
    particle.Transparency = config.Transparency or NumberSequence.new(0)
    particle.Rotation = config.Rotation or NumberRange.new(0, 360)
    particle.RotSpeed = config.RotSpeed or NumberRange.new(0)
    
    if config.Duration then
        Debris:AddItem(particle, config.Duration)
    end
    
    return particle
end

local function CreateLight(parent, config)
    local light = Instance.new("PointLight")
    light.Parent = parent
    light.Brightness = config.Brightness or 5
    light.Range = config.Range or 20
    light.Color = config.Color or Color3.fromRGB(255, 255, 255)
    
    if config.Duration then
        Debris:AddItem(light, config.Duration)
    end
    
    return light
end

local function CreateSound(parent, soundId, volume, duration)
    local sound = Instance.new("Sound")
    sound.Parent = parent
    sound.SoundId = soundId
    sound.Volume = volume or 1
    sound:Play()
    
    Debris:AddItem(sound, duration or 3)
    
    return sound
end

local function CreateExplosion(position, config)
    local explosion = Instance.new("Explosion")
    explosion.Position = position
    explosion.BlastRadius = config.BlastRadius or 10
    explosion.BlastPressure = config.BlastPressure or 500000
    explosion.DestroyJointRadiusPercent = 0
    explosion.Parent = workspace
    
    local explosionPart = Instance.new("Part")
    explosionPart.Size = Vector3.new(1, 1, 1)
    explosionPart.Material = Enum.Material.Neon
    explosionPart.Color = config.Color or Color3.fromRGB(255, 100, 0)
    explosionPart.Anchored = true
    explosionPart.CanCollide = false
    explosionPart.Shape = Enum.PartType.Ball
    explosionPart.Position = position
    explosionPart.Transparency = 0.3
    explosionPart.Parent = workspace
    
    CreateLight(explosionPart, {
        Brightness = 20,
        Range = config.BlastRadius or 10,
        Color = config.Color or Color3.fromRGB(255, 100, 0),
        Duration = 0.5
    })
    
    CreateParticle(explosionPart, {
        Texture = "rbxasset://textures/particles/fire_main.dds",
        Color = ColorSequence.new(config.Color or Color3.fromRGB(255, 100, 0)),
        Rate = 200,
        Lifetime = NumberRange.new(1),
        Speed = NumberRange.new(20),
        Duration = 0.5
    })
    
    TweenService:Create(explosionPart, TweenInfo.new(0.5), {
        Size = Vector3.new(config.BlastRadius or 10, config.BlastRadius or 10, config.BlastRadius or 10),
        Transparency = 1
    }):Play()
    
    Debris:AddItem(explosionPart, 0.5)
    
    return explosion
end

local function CreateBeam(startPos, endPos, config)
    local distance = (startPos - endPos).Magnitude
    
    local beam = Instance.new("Part")
    beam.Size = Vector3.new(config.Width or 2, config.Width or 2, distance)
    beam.Material = Enum.Material.Neon
    beam.Color = config.Color or Color3.fromRGB(0, 150, 255)
    beam.Anchored = true
    beam.CanCollide = false
    beam.CFrame = CFrame.new(startPos, endPos) * CFrame.new(0, 0, -distance / 2)
    beam.Transparency = config.Transparency or 0.3
    beam.Parent = workspace
    
    local mesh = Instance.new("CylinderMesh")
    mesh.Parent = beam
    
    CreateLight(beam, {
        Brightness = 20,
        Range = 30,
        Color = config.Color or Color3.fromRGB(0, 150, 255),
        Duration = config.Duration or 0.5
    })
    
    CreateParticle(beam, {
        Texture = "rbxasset://textures/particles/sparkles_main.dds",
        Color = ColorSequence.new(config.Color or Color3.fromRGB(0, 150, 255)),
        Rate = 100,
        Lifetime = NumberRange.new(0.5),
        Speed = NumberRange.new(10),
        Duration = config.Duration or 0.5
    })
    
    if config.Duration then
        Debris:AddItem(beam, config.Duration)
    end
    
    return beam
end

