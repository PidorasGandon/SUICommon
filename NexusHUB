local function ScanRemotes()
    RemoteEvents = {}
    RemoteFunctions = {}
    
    for _, obj in pairs(game:GetDescendants()) do
        if obj:IsA("RemoteEvent") then
            table.insert(RemoteEvents, obj)
        elseif obj:IsA("RemoteFunction") then
            table.insert(RemoteFunctions, obj)
        end
    end
    
    print("🔍 Найдено RemoteEvents: " .. #RemoteEvents)
    print("🔍 Найдено RemoteFunctions: " .. #RemoteFunctions)
end

ScanRemotes()

local function FireRemote(remoteName, ...)
    for _, remote in pairs(RemoteEvents) do
        if remote.Name:lower():find(remoteName:lower()) then
            pcall(function()
                remote:FireServer(...)
            end)
            print("🚀 Fired: " .. remote:GetFullName())
            return true
        end
    end
    return false
end

local function SpamAllRemotes(args)
    for _, remote in pairs(RemoteEvents) do
        pcall(function()
            remote:FireServer(unpack(args))
        end)
    end
    print("💥 Спамлено " .. #RemoteEvents .. " RemoteEvents!")
end

