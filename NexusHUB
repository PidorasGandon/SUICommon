-- Функция создания таба
local function CreateTab(name, icon, color, callback)
    local Tab = Instance.new("TextButton")
    Tab.Name = name
    Tab.Parent = TabsContainer
    Tab.BackgroundColor3 = Color3.fromRGB(20, 20, 30)
    Tab.Size = UDim2.new(0, 140, 0, 50)
    Tab.Font = Enum.Font.GothamBold
    Tab.Text = icon .. " " .. name
    Tab.TextColor3 = Color3.fromRGB(150, 150, 150)
    Tab.TextSize = 13
    Tab.ZIndex = 3
    
    local TabCorner = Instance.new("UICorner")
    TabCorner.CornerRadius = UDim.new(0, 10)
    TabCorner.Parent = Tab
    
    local TabStroke = Instance.new("UIStroke")
    TabStroke.Parent = Tab
    TabStroke.Color = color
    TabStroke.Thickness = 2
    TabStroke.Transparency = 1
    
    Tab.MouseButton1Click:Connect(function()
        currentTab = name
        
        for _, tab in pairs(TabsContainer:GetChildren()) do
            if tab:IsA("TextButton") then
                local stroke = tab:FindFirstChildOfClass("UIStroke")
                if tab.Name == name then
                    TweenService:Create(tab, TweenInfo.new(0.2), {
                        BackgroundColor3 = color,
                        TextColor3 = Color3.fromRGB(255, 255, 255)
                    }):Play()
                    if stroke then
                        TweenService:Create(stroke, TweenInfo.new(0.2), {Transparency = 0}):Play()
                    end
                else
                    TweenService:Create(tab, TweenInfo.new(0.2), {
                        BackgroundColor3 = Color3.fromRGB(20, 20, 30),
                        TextColor3 = Color3.fromRGB(150, 150, 150)
                    }):Play()
                    if stroke then
                        TweenService:Create(stroke, TweenInfo.new(0.2), {Transparency = 1}):Play()
                    end
                end
            end
        end
        
        for _, child in pairs(ScrollFrame:GetChildren()) do
            if not child:IsA("UIListLayout") then
                child:Destroy()
            end
        end
        
        callback()
    end)
    
    return Tab
end

