            Size = Vector3.new(0, 0, 0),
            Transparency = 1
        }):Play()
        
        game.Lighting.TimeOfDay = "14:00:00"
        game.Lighting.Ambient = Color3.fromRGB(127, 127, 127)
        
        wait(2)
        marble:Destroy()
    end)
